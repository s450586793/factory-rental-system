# GHCR deployment reference checklist.
# docker-compose.ghcr.yml is self-contained and can be pasted into Synology GUI directly.
# This file is only for recording the values you plan to substitute in that compose file.

BACKEND_IMAGE=ghcr.io/s450586793/factory-rental-system-backend:latest
FRONTEND_IMAGE=ghcr.io/s450586793/factory-rental-system-frontend:latest

TZ=Asia/Shanghai

POSTGRES_DB=factory_rental
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-strong-password

DB_PORT=5432
DB_NAME=factory_rental
DB_USER=postgres
DB_PASSWORD=replace-with-a-strong-password
DB_SYNCHRONIZE=false

APP_NAME=factory-rental-system
NODE_ENV=production
JWT_SECRET=replace-with-a-long-random-secret
COOKIE_NAME=token
COOKIE_SECURE=true
FRONTEND_ORIGIN=https://your-domain.example.com
PDF_FONT_PATH=/usr/share/fonts/opentype/noto/NotoSansCJK-Regular.ttc

ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-admin-password
